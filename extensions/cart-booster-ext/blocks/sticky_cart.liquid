{% assign config = app.metafields.aov_booster.sticky_cart_config.value %}
{% assign is_preview = request.design_mode %}

{% if request.page_type == 'product' or is_preview %}
  {% if config.isActive or is_preview %}
    {% assign position_class = 'aov-sticky-cart--bottom' %}
    {% if config.position == 'top' %}
      {% assign position_class = 'aov-sticky-cart--top' %}
    {% endif %}

    {% assign mobile_only_class = '' %}
    {% if config.hideOnDesktop and is_preview == false %}
      {% assign mobile_only_class = 'aov-sticky-cart--mobile-only' %}
    {% endif %}

    {% if config.hideOnDesktop and is_preview == false %}
      <style>
        @media (min-width: 768px) {
          #aov-sticky-cart.aov-sticky-cart--mobile-only {
            display: none !important;
          }
        }
      </style>
    {% endif %}

    {% assign display_title = product.title | default: 'Örnek Ürün Adı' %}
    {% assign display_price = product.price | default: 19900 %}

    <div
      id="aov-sticky-cart"
      class="aov-sticky-cart {{ position_class }} {{ mobile_only_class }}{% if is_preview %} aov-sticky-cart--editor-preview{% endif %}"
      style="--aov-btn-color: {{ config.buttonColor | default: '#000000' }};"
      data-config="{% if config %}{{ config | json | escape }}{% else %}{}{% endif %}"
      data-preview="{{ is_preview }}"
      role="complementary"
      aria-label="Yapışkan sepete ekle"
      aria-hidden="{% if is_preview %}false{% else %}true{% endif %}"
    >
      {% if product.featured_image %}
        <div class="aov-sticky-cart__media">
          {{
            product.featured_image
            | image_url: width: 120
            | image_tag: alt: display_title, loading: 'lazy', widths: '48, 96, 120'
          }}
        </div>
      {% elsif is_preview %}
        <div class="aov-sticky-cart__media aov-sticky-cart__media--placeholder" aria-hidden="true"></div>
      {% endif %}

      <div class="aov-sticky-cart__info">
        <p class="aov-sticky-cart__title">{{ display_title | escape }}</p>
        <p class="aov-sticky-cart__price">{{ display_price | money }}</p>
      </div>

      <button type="button" class="aov-sticky-cart__button">
        {{ config.buttonText | default: 'Sepete Ekle' | escape }}
      </button>
    </div>
  {% endif %}
{% endif %}

{% schema %}
{
  "name": "t:blocks.sticky_cart.name",
  "target": "section",
  "javascript": "aov-sticky-cart.js",
  "stylesheet": "aov-sticky-cart.css",
  "settings": []
}
{% endschema %}
