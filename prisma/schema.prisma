// schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:dev.sqlite"
}

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model ShippingBarWidget {
  id                 String  @id @default(uuid())
  shop               String  @unique
  isActive           Boolean @default(false)
  goalAmount         Int     @default(500)
  currency           String  @default("TRY")
  initialMessage     String  @default("Kargo bedava fırsatını yakala!")
  progressMessage    String  @default("Kargoya sadece [amount] kaldı!")
  successMessage     String  @default("Tebrikler, Kargo Bedava!")
  barColor           String  @default("#000000")
  progressColor      String  @default("#22c55e")
  textColor          String  @default("#ffffff")
  trackColor         String  @default("#ffffff40")
  barHeight          Int     @default(56)
  fontSize           Int     @default(16)
  fontFamily         String  @default("inherit")
  trackHeight        Int     @default(8)
  /// Arka plan görseli URL'si. Boş string = düz renk kullan.
  backgroundImageUrl String  @default("")
}

model StickyCartWidget {
  id            String  @id @default(uuid())
  shop          String  @unique
  isActive      Boolean @default(false)
  position      String  @default("bottom")
  buttonColor   String  @default("#000000")
  buttonText    String  @default("Sepete Ekle")
  hideOnDesktop Boolean @default(false)
}

/// Dev-bypass Pro subscription (shop-scoped)
model ShopProSubscription {
  shop      String   @id
  plan      String
  isTest    Boolean  @default(true)
  updatedAt DateTime @updatedAt
}

/// ROI Analytics - AOV Booster widget'larından etkilenen gelir
model ShopAnalytics {
  id               String   @id @default(uuid())
  shop             String   @unique
  totalRoi         Float    @default(0)
  ordersInfluenced Int      @default(0)
  currency         String   @default("TRY")
  updatedAt        DateTime @updatedAt
}

/// ROI sayımında çifte kayıtı önlemek için (webhook + Admin sync)
model InfluencedOrder {
  shop      String
  orderId   String
  amount    Float
  currency  String
  createdAt DateTime @default(now())

  @@id([shop, orderId])
}
